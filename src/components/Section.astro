---
interface Props {
  id: string;
  title: string;
  wide?: boolean;
}

const { id, title, wide = false } = Astro.props;
---

<section id={id} class="border-b border-border">
  <div class:list={['mx-auto px-6 py-14', wide ? 'max-w-wide' : 'max-w-prose']}>
    <h2 class="mb-8 text-3xl font-semibold text-foreground">{title}</h2>
    <slot />
  </div>
</section>
