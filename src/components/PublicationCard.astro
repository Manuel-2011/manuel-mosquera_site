---
import type { Publication } from '../data/site';

interface Props {
  publication: Publication;
}

const { publication } = Astro.props;
---

<article class="rounded-lg border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  <div class="mb-3 flex flex-wrap items-center gap-2">
    <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-accent">
      {publication.venue} {publication.year}
    </span>
    <span class="text-xs font-medium uppercase tracking-wide text-muted">{publication.role}</span>
  </div>
  <h3 class="mb-3 text-xl font-semibold leading-snug text-foreground">
    <a href={publication.url} target="_blank" rel="noopener noreferrer" class="no-underline hover:text-accent">
      {publication.title}
    </a>
  </h3>
  <p class="mb-4 leading-relaxed text-muted">{publication.summary}</p>
  <a
    href={publication.url}
    target="_blank"
    rel="noopener noreferrer"
    class="text-sm font-medium no-underline hover:text-foreground"
  >
    View paper →
  </a>
</article>
